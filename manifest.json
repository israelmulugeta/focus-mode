{
  "manifest_version": 3,
  "name": "Focus Extension",
  "description": "Stay focused by blocking distracting websites and applying grayscale during focus sessions.",
  "version": "1.0.0",
  "permissions": ["storage", "tabs", "alarms", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Focus Extension"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
